# --- Database ------------------------------------------------------------
# Local dev: docker-compose Postgres on :5433 (avoids clash with landing-2026)
# Prod: point both DATABASE_URL and AUTH_DATABASE_URL at the shared Railway DB
DATABASE_URL=postgresql://nullv2:nullv2_dev@localhost:5433/nullv2

# DB that owns users/sessions/magic_links (landing-2026).
# In prod this equals DATABASE_URL. In dev it points at your local landing-2026
# Postgres so sessions issued by landing-2026 are verifiable here.
AUTH_DATABASE_URL=postgresql://nullv2:nullv2_dev@localhost:5433/nullv2

# --- Auth ----------------------------------------------------------------
# Cookie name landing-2026 sets. Must match.
AUTH_COOKIE_NAME=session
# Set to .oniondao.dev in prod so the cookie is readable across subdomains.
AUTH_COOKIE_DOMAIN=

# --- API -----------------------------------------------------------------
API_PORT=3100
PUBLIC_API_URL=http://localhost:3100

# --- Tick worker ---------------------------------------------------------
TICK_INTERVAL_MS=300000

# --- Webapp --------------------------------------------------------------
WEBAPP_PORT=3101

# --- Inference -----------------------------------------------------------
# Wraps the Vercel AI SDK against any OpenAI-compatible endpoint
# (OpenAI, Together AI, Groq, OpenRouter, local LM Studio, etc.).
INFERENCE_PORT=3102
INFERENCE_BASE_URL=https://api.openai.com/v1
INFERENCE_API_KEY=
INFERENCE_MODEL=gpt-4o-mini
INFERENCE_MAX_TOKENS=400

# --- Object storage (resident avatars) -----------------------------------
# S3-compatible bucket — shared with landing-2026's MinIO on Railway.
# Copy these from landing-2026's .env (S3_ENDPOINT/S3_BUCKET/S3_ACCESS_KEY_ID/S3_SECRET_ACCESS_KEY).
# Bucket must allow public-read on uploaded objects for the public URL to resolve.
S3_ENDPOINT=
S3_BUCKET=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=

# --- Railway deployment --------------------------------------------------
# Used only by scripts/deploy-railway.sh. Any value set here skips its
# corresponding prompt. Leave blank to be prompted at deploy time.

# Project ID of the landing-2026 Railway project (nullv2 services get added
# alongside it). Grab from the project's dashboard URL. If empty, the script
# falls back to `railway link` interactive picker.
RAILWAY_PROJECT_ID=

# Name of the Postgres service inside landing-2026's project. "Postgres" is
# Railway's default for managed Postgres — rename if landing-2026 named theirs
# differently. The script references it as ${{<this-name>.DATABASE_URL}}.
POSTGRES_SERVICE=Postgres

# --- Database ------------------------------------------------------------
# Local dev: docker-compose Postgres on :5433 (avoids clash with landing-2026)
# Prod: point both DATABASE_URL and AUTH_DATABASE_URL at the shared Railway DB
DATABASE_URL=postgresql://nullv2:nullv2_dev@localhost:5433/nullv2

# DB that owns users/sessions/magic_links (landing-2026).
# In prod this equals DATABASE_URL. In dev it points at your local landing-2026
# Postgres so sessions issued by landing-2026 are verifiable here.
AUTH_DATABASE_URL=postgresql://nullv2:nullv2_dev@localhost:5433/nullv2

# --- Auth ----------------------------------------------------------------
# Cookie name landing-2026 sets. Must match.
AUTH_COOKIE_NAME=session
# Set to .oniondao.dev in prod so the cookie is readable across subdomains.
AUTH_COOKIE_DOMAIN=

# --- API -----------------------------------------------------------------
API_PORT=3100
PUBLIC_API_URL=http://localhost:3100

# --- Tick worker ---------------------------------------------------------
TICK_INTERVAL_MS=300000

# --- Webapp --------------------------------------------------------------
WEBAPP_PORT=3101

# --- Inference -----------------------------------------------------------
# Wraps the Vercel AI SDK against any OpenAI-compatible endpoint
# (OpenAI, Together AI, Groq, OpenRouter, local LM Studio, etc.).
INFERENCE_PORT=3102
INFERENCE_BASE_URL=https://api.openai.com/v1
INFERENCE_API_KEY=
INFERENCE_MODEL=gpt-4o-mini
INFERENCE_MAX_TOKENS=400

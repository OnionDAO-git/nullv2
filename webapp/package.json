    "html2canvas": "^1.4.1",
    "lucide-svelte": "^0.563.0",
    "qrcode": "^1.5.4",
    "three": "^0.182.0"
  },
  "devDependencies": {
    "@sveltejs/adapter-node": "^5.3.1",
    "@sveltejs/kit": "^2.50.2",
    "@sveltejs/vite-plugin-svelte": "^6.2.4",
    "@tailwindcss/typography": "^0.5.19",
    "@tailwindcss/vite": "^4.1.18",
    "@types/node": "^25.2.2",
    "@types/qrcode": "^1.5.6",
    "@types/three": "^0.182.0",
    "svelte": "^5.49.2",
    "svelte-check": "^4.3.6",
